{
  "name": "Rayfield Gen2 Tests",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Rayfield": {
        "$path": "src"
      },
      "Tests": {
        "$path": "tests/specs"
      },
      "TestEZ": {
        "$path": "build/TestEZ.rbxm"
      }
    },

    "ServerScriptService": {
      "RunTests": {
        "$path": "tests/run.server.luau"
      }
    }
  }
}
